# Local PostgreSQL
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/mergenote

# GitHub token (repo scope needed for reading PRs and writing releases)
GITHUB_TOKEN=

# GitHub OAuth App (for user login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# JWT secret for session cookies
JWT_SECRET=change-me-in-production

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:3200

# PayPal Sandbox credentials
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=sandbox

# Optional: map PayPal plan ID to license tier
PAYPAL_PREMIUM_PLAN_ID=

# Mergenote license key (set this in Claude Desktop config to unlock paid features)
MERGENOTE_LICENSE_KEY=

# Licensing backend
LICENSE_API_URL=http://localhost:3100
LICENSE_API_SECRET=change-me-in-production

# Server ports
BACKEND_PORT=3100
WEBSITE_PORT=3200
MCP_HTTP_PORT=3300
