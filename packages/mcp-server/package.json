{
  "name": "mergenote",
  "version": "1.1.0",
  "description": "MCP server that turns merged GitHub PRs into clean release notes",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mergenote": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/http.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "release-notes",
    "changelog",
    "github",
    "pull-requests",
    "model-context-protocol"
  ],
  "author": "Mergenote",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devpilotX/mergenote.git",
    "directory": "packages/mcp-server"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@octokit/rest": "^22.0.1",
    "dotenv": "16.6.1",
    "zod": "^3.25.34"
  },
  "devDependencies": {
    "@types/node": "20.17.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "3.2.3"
  },
  "engines": {
    "node": ">=20"
  }
}
